# Server-side example for deployment hosts
SPC_SERVER_PORT=8080
SPC_SERVER_CONTEXT_PATH=/spc/api

SPC_DB_URL=jdbc:mysql://mysql:3306/spc_db?useSSL=false&allowPublicKeyRetrieval=true&characterEncoding=UTF-8&serverTimezone=Asia/Seoul
SPC_DB_USERNAME=spc_user
SPC_DB_PASSWORD=change-me

SPC_JWT_SECRET=change-me-base64

SPC_REDIS_HOST=redis
SPC_REDIS_PORT=6379

# Frontend build/runtime
VITE_SPC_APP_BASE_PATH=/spc/
VITE_SPC_API_BASE_URL=/spc/api

# Orval code generation
SPC_ORVAL_INPUT_TARGET=http://127.0.0.1:8080/spc/api/v3/api-docs
